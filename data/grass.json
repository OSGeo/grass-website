    "install": {
        "mac": {
            "binaries" : [
                {
                    "id": "grass-mac",
                    "title": "GRASS for the Mac (binary installers)",
                    "url": "https://cmbarton.github.io/grass-mac/download/"
                }
            ],
            "installers": {
                "mac_ports": {
                    "id": "mac_ports",
                    "title": "MacPorts",
                    "code": "sudo port install grass",
                    "url": {
                        "href": "https://ports.macports.org/port/grass/",
                        "label": "MacPorts GRASS"
                    }
                }
            }
        },
        "linux":{
            "installers": {

                "ubuntu": {
                    "id": "01_ubuntu",
                    "title": "Ubuntu",
                    "pre_install": [
                        {"id": "ubuntu_comment_1", "text": "Add the ubuntugis-unstable PPA to your system:", "code": "sudo add-apt-repository ppa:ubuntugis/ubuntugis-unstable"},
                        {"id": "ubuntu_comment_2", "text": "Update your package list:", "code": "sudo apt update"}
                    ],
                    "code": "sudo apt install grass",
                    "url": {
                        "href": "https://launchpad.net/~ubuntugis/+archive/ubuntu/ubuntugis-unstable",
                        "label": "ubuntugis-unstable"
                    }
                },
                "generic_64_bit":{
                    "id": "02_generic_64_bit",
                    "title": "Generic 64-bit",
                    "pre_install": [
                        {"id": "generic_64_bit_comment_1", "text": "Download the latest weekly GRASS binary snapshot from https://grass.osgeo.org/grass85/binary/linux/snapshot/ and make it executable:", "code": "chmod +x grass-*-x86_64-pc-linux-gnu-*-install.sh"}
                    ],
                    "code": "sh grass-*-x86_64-pc-linux-gnu-*-install.sh",
                    "url": {
                        "href": "https://grass.osgeo.org/grass85/binary/linux/snapshot/",
                        "label": "snapshots"
                    }
                },
                "debian": {
                    "id": "03_debian",
                    "title": "Debian",
                    "code": "sudo apt install grass",
                    "url": {
                        "href": "https://packages.debian.org/grass",
                        "label": "debian packages"
                    }
                },
                "fedora":{
                    "id": "04_fedora",
                    "title": "Fedora",
                    "code": "sudo dnf install grass",
                    "url": {
                        "href": "https://packages.fedoraproject.org/pkgs/grass/grass/",
                        "label": "Fedora packages"
                    }
                },
                "EPEL": {
                    "id": "EPEL",
                    "title": "EPEL8",
                    "code": "sudo yum install grass",
                    "url": {
                        "href": "https://packages.fedoraproject.org/pkgs/grass/grass/",
                        "label": "EPEL8 (RHEL8/Centos8) packages"
                    }
                },
                "arch_linux": {
                    "id": "arch_linux",
                    "title": "Arch Linux",
                    "code": "sudo pacman -S grass",
                    "url": {
                        "href": "https://aur.archlinux.org/packages/grass/",
                        "label": "Arch Linux packages"
                    }
                },
                "gentoo": {
                    "id": "gentoo",
                    "title": "Gentoo",
                    "code": "sudo emerge grass",
                    "url": {
                        "href": "https://packages.gentoo.org/packages/sci-geosciences/grass",
                        "label": "Gentoo packages"
                    }
                },
                "mageia": {
                    "id": "mageia",
                    "title": "Mageia",
                    "code": "sudo dnf install grass",
                    "url": {
                        "href": "https://madb.mageia.org/package/show/name/grass/",
                        "label": "Mageia packages"
                    }
                },
                "openSUSE": {
                    "id": "openSUSE",
                    "title": "openSUSE",
                    "code": "sudo zypper install grass",
                    "url": {
                        "href": "https://build.opensuse.org/package/show/Application:Geo/grass",
                        "label": "openSUSE packages"
                    }
                }
            }
        },
        "windows": {
            "binaries" : [
                {
                    "id": "osgeo4w-v2",
                    "title": "OSGeo4W installer (v2, 64-bit)",
                    "url": "https://download.osgeo.org/osgeo4w/v2/osgeo4w-setup.exe"
                },
                {
                    "id": "osgeo4w-v1-64",
                    "title": "OSGeo4W installer (v1, 64-bit, legacy)",
                    "url": "https://download.osgeo.org/osgeo4w/v1/osgeo4w-setup-x86_64-v1.exe"
                },
                {
                    "id": "osgeo4w-v1-32",
                    "title": "OSGeo4W installer (v1, 32-bit, legacy)",
                    "url": "https://download.osgeo.org/osgeo4w/v1/osgeo4w-setup-x86-v1.exe"
                },
                {
                    "id": "standalone-legacy",
                    "title": "Standalone installer (v8.4.2 legacy, 64-bit)",
                    "url": "https://grass.osgeo.org/grass84/binary/mswindows/native/WinGRASS-8.4.2-1-Setup.exe"
                }
            ],
            "installers": {
                "osgeo4w64": {
                    "id": "osgeo4w64",
                    "title": "OSGeo4W",
                    "code": "osgeo4w-setup.exe -q -k -P grass -s https://download.osgeo.org/osgeo4w/v2/x86_64/"
                }
            }
        },
        "docker": {
            "installers": {
                "alpine": {
                    "id": "alpine",
                    "title": "Alpine based (233 MB, with Python 3 and PDAL)",
                    "code": "docker pull osgeo/grass-gis:releasebranch_8_5-alpine"
                },
                "debian": {
                    "id": "debian",
                    "title": "Debian based (1.2 GB, with Python 3 and PDAL)",
                    "code": "docker pull osgeo/grass-gis:releasebranch_8_5-debian"
                },
                "ubuntu": {
                    "id": "ubuntu",
                    "title": "Ubuntu based (1.2 GB, with Python 3 and PDAL)",
                    "code": "docker pull osgeo/grass-gis:releasebranch_8_5-ubuntu"
                },
                "wxPython": {
                    "id": "wxPython",
                    "title": "Ubuntu based (1.3 GB, with wxPython, Python 3 and PDAL)",
                    "code": "docker pull osgeo/grass-gis:releasebranch_8_5-ubuntu_wxgui"
                }
            }
        }

    }

}
